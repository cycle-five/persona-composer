# persona-composer LLM gateway configuration
#
# The gateway speaks the OpenAI-compatible /chat/completions protocol, so the
# same three variables point it at OpenAI, a local Ollama/koboldcpp/text-gen-webui
# server, an Anthropic-compatible proxy, an aggregator (LiteLLM/OpenRouter), or
# Amazon Bedrock's OpenAI-compatible endpoint. Copy this file to `.env` and edit.

# Base URL of the OpenAI-compatible API. Include the version path if the
# provider uses one. Examples:
#   OpenAI:           https://api.openai.com/v1
#   Ollama:           http://127.0.0.1:11434/v1
#   koboldcpp:        http://127.0.0.1:5001/v1
#   text-gen-webui:   http://127.0.0.1:5000/v1
#   LiteLLM proxy:    http://127.0.0.1:4000
#   AWS Bedrock:      https://bedrock-runtime.us-east-1.amazonaws.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key. Leave blank for most local servers (Ollama/kobold accept anything).
# For AWS Bedrock, use an Amazon Bedrock API key (a bearer token) — see below.
LLM_API_KEY=

# Model name as the endpoint expects it.
#   OpenAI:   gpt-4o-mini
#   Ollama:   llama3.1  (or whatever you've pulled)
#   Bedrock:  us.anthropic.claude-sonnet-4-6  (use the exact id/profile you use)
LLM_MODEL=gpt-4o-mini

# --- AWS Bedrock --------------------------------------------------------------
# Bedrock exposes a native OpenAI-compatible Chat Completions endpoint, so no
# code or proxy is needed — just set the three vars above:
#   LLM_BASE_URL=https://bedrock-runtime.<region>.amazonaws.com/v1
#                (or https://bedrock-mantle.<region>.api.aws/v1 — broader catalog,
#                 but no cross-region inference profiles)
#   LLM_API_KEY=<Amazon Bedrock API key>   # bearer token; Bedrock console → API keys
#   LLM_MODEL=<the model id/inference profile you already use>
# The API key principal needs bedrock:InvokeModelWithResponseStream (+ InvokeModel)
# on the model. Long-term keys create a Bedrock-scoped IAM user automatically;
# short-term keys inherit your session and expire in <=12h.
# Docs: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-chat-completions-mantle.html

# Optional sampling controls (sent only if set).
# LLM_TEMPERATURE=0.9
# LLM_MAX_TOKENS=512

# Optional: inactivity timeout in milliseconds (default 60000). The stream is
# aborted only if no data arrives within this window; it resets on every chunk,
# so a long but healthy generation is never cut off.
# LLM_TIMEOUT_MS=60000

# --- Standalone dev server (npm start) only --------------------------------
# Port the standalone server listens on. Ignored when running inside ST.
PERSONA_COMPOSER_PORT=5859

# Directory to load persona character cards from.
# Defaults to the `personas/` dir shipped next to the build. Override to point
# at your own card collection.
# PERSONA_COMPOSER_PERSONAS_DIR=/abs/path/to/personas
