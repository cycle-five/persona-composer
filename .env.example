# persona-composer LLM gateway configuration
#
# The gateway speaks the OpenAI-compatible /chat/completions protocol, so the
# same three variables point it at OpenAI, a local Ollama/koboldcpp/text-gen-webui
# server, or an Anthropic-compatible proxy. Copy this file to `.env` and edit.
#
# When running as a SillyTavern server-plugin, set these in the environment that
# launches SillyTavern (e.g. your shell rc, a systemd unit, or ST's start script)
# — the plugin reads process.env at request time.

# Base URL of the OpenAI-compatible API. Include the version path if the
# provider uses one. Examples:
#   OpenAI:           https://api.openai.com/v1
#   Ollama:           http://127.0.0.1:11434/v1
#   koboldcpp:        http://127.0.0.1:5001/v1
#   text-gen-webui:   http://127.0.0.1:5000/v1
#   LiteLLM proxy:    http://127.0.0.1:4000
LLM_BASE_URL=https://api.openai.com/v1

# API key. Leave blank for most local servers (Ollama/kobold accept anything).
LLM_API_KEY=

# Model name as the endpoint expects it.
#   OpenAI:   gpt-4o-mini
#   Ollama:   llama3.1  (or whatever you've pulled)
LLM_MODEL=gpt-4o-mini

# Optional sampling controls (sent only if set).
# LLM_TEMPERATURE=0.9
# LLM_MAX_TOKENS=512

# Optional: request timeout in milliseconds (default 60000).
# LLM_TIMEOUT_MS=60000

# --- Standalone dev server (npm start) only --------------------------------
# Port the standalone server listens on. Ignored when running inside ST.
PERSONA_COMPOSER_PORT=5859

# Directory to load persona character cards from.
# Defaults to the `personas/` dir shipped next to the build. Override to point
# at your own card collection.
# PERSONA_COMPOSER_PERSONAS_DIR=/abs/path/to/personas
