{
  "name": "persona-composer",
  "version": "0.1.0",
  "description": "Compose social-media posts in the voice of AI personas, backed by SillyTavern character cards and any OpenAI-compatible LLM.",
  "license": "MIT",
  "author": "Cycle Five",
  "type": "commonjs",
  "main": "dist/plugin.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "dev": "tsc -p tsconfig.json && node dist/server.js",
    "start": "node dist/server.js",
    "build:ext": "node extension/build.mjs",
    "watch:ext": "node extension/build.mjs --watch",
    "build:all": "npm run build && npm run build:ext",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p extension/tsconfig.json --noEmit",
    "clean": "rm -rf dist extension/dist"
  },
  "keywords": [
    "sillytavern",
    "persona",
    "social-media",
    "llm",
    "openai-compatible"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "esbuild@0.24.2": true
  }
}
